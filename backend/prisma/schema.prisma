generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid()) @map("user_id")
  email              String    @unique
  password_hash      String
  email_verified     Boolean   @default(false)
  name               String
  role               UserRole  @default(USER)
  is_active          Boolean   @default(true)
  verification_token String?
  reset_token        String?
  reset_token_expiry DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  last_login_at      DateTime?
  resumes            Resume[]  // ADD THIS LINE

  analyses  Analysis[]

  optimizations ResumeOptimization[]

  @@index([email])
  @@index([role])
  @@index([created_at])
  @@map("users")
}

// ADD THIS ENTIRE MODEL
model Resume {
  id         String   @id @default(uuid())
  user_id    String   // Changed from userId to user_id to match your convention
  title      String
  template_id String  @default("modern") @map("templateId")
  content    Json
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  analyses  Analysis[]

  optimizations ResumeOptimization[]
  
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  @@index([user_id])
  @@map("resumes")
}

enum UserRole {
  USER
  ADMIN
  CAREER_COUNSELOR
}


// ─── ADD THIS MODEL ───────────────────────────────────────────────────────────

model Analysis {
  id                String   @id @default(uuid())
  resume_id         String
  user_id           String

  analysis_type     String   // "health" | "job_match"
  job_description   String?
  job_title         String?
  company           String?

  overall_score     Int?
  match_score       Int?

  structure_score   Int?
  keyword_score     Int?
  impact_score      Int?
  skills_score      Int?
  readability_score Int?

  strengths         Json
  weaknesses        Json
  suggestions       Json

  matched_keywords  Json?
  missing_keywords  Json?

  // ML-ready feature vector — stored for future model training
  feature_vector    Json?

  created_at        DateTime @default(now())

  resume Resume @relation(fields: [resume_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id],   references: [id], onDelete: Cascade)

  @@index([resume_id])
  @@index([user_id])
  @@map("analysis_results")
}



model ResumeOptimization {
  id          String   @id @default(uuid())
  resume_id   String
  user_id     String
  analysis_id String?
  section     String   // "summary" | "experience" | "skills" | "projects"
  original    String
  optimized   String
  mode        String   // "health" | "job_match"
  accepted    Boolean  @default(false)
  created_at  DateTime @default(now())

  resume Resume @relation(fields: [resume_id], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [user_id],   references: [id], onDelete: Cascade)

  @@index([resume_id])
  @@index([user_id])
  @@map("resume_optimizations")
}